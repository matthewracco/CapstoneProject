# Database
PLATFORM_DB_URI=mongodb://localhost:27017/locker_platform
TENANT_DB_URI=mongodb://localhost:27017/locker_tenant_{tenantId}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Server
PORT=5000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
