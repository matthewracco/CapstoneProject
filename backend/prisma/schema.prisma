generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         String    @default("CUSTOMER") // CUSTOMER | STAFF | OWNER
  failedLogins Int       @default(0)
  lockedUntil  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model Locker {
  id           String   @id @default(cuid())
  tenantId     String
  location     String
  lockerNumber String

  // AVAILABLE | OCCUPIED | MAINTENANCE | ASSIGNED
  status     String @default("AVAILABLE")
  assignedTo String?
  qrCode     String?
  accessCode String?
  accessCodeExpiry DateTime?
  // SMALL | MEDIUM | LARGE
  type String @default("MEDIUM")
  // STANDARD | PREMIUM
  tier String @default("STANDARD")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rentals Rental[]

  @@unique([tenantId, lockerNumber])
  @@index([tenantId, status])
  @@index([tenantId, location])
}

model Rental {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  lockerId String

  startTime  DateTime  @default(now())
  endTime    DateTime?
  maxEndTime DateTime? // 48hr cap from start

  // ACTIVE | COMPLETED | CANCELLED | OVERDUE
  status String @default("ACTIVE")

  rentalCode    String @unique
  totalCost     Float  @default(0)
  // PENDING | COMPLETED | FAILED
  paymentStatus String @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locker   Locker    @relation(fields: [lockerId], references: [id])
  payments Payment[]

  @@index([tenantId, userId])
  @@index([tenantId, status])
}

model Payment {
  id       String @id @default(cuid())
  tenantId String
  rentalId String
  userId   String
  amount   Float
  method   String @default("mock_card") // mock_card | mock_card_fail | mock_wallet | subscription
  status   String @default("PENDING")   // PENDING | SUCCESS | FAILED

  createdAt DateTime @default(now())

  rental Rental @relation(fields: [rentalId], references: [id])

  @@index([tenantId, userId])
}

model Notification {
  id       String  @id @default(cuid())
  tenantId String
  userId   String
  type     String  // RENTAL_CONFIRMATION | EXPIRY_WARNING | RENTAL_EXPIRED | RENTAL_OVERDUE | APPROVAL_GRANTED | LOCKER_ASSIGNED
  title    String
  body     String
  read     Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, userId, read])
}

model TenantConfig {
  id               String  @id @default(cuid())
  tenantId         String  @unique
  mode             String  @default("PUBLIC")
  maxDurationHours Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
